{
  "name": "championcreator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "generate:battle-options": "node scripts/generate-battle-options.mjs",
    "generate:localization-seed": "node scripts/generate-localization-seed.mjs",
    "generate:move-hit-counts": "node scripts/add-move-hit-counts.mjs",
    "generate:pokemon-abilities": "node scripts/generate-pokemon-abilities.mjs",
    "validate:artwork-assets": "node scripts/validate-artwork-assets.mjs",
    "validate:localization": "node scripts/validate-localization.mjs",
    "validate:pokemon-abilities": "node scripts/validate-pokemon-abilities.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run validate:localization && npm run validate:pokemon-abilities && npm run validate:artwork-assets && npm test && npm run build",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@smogon/calc": "file:vendor/smogon-calc-0.11.0-49d4d86.tgz",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
